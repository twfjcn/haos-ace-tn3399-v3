# CONFIG_CPU_FREQ_DEFAULT_GOV_ONDEMAND is not set
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y

CONFIG_THERMAL_GOV_BANG_BANG=y
CONFIG_SENSORS_GPIO_FAN=y

CONFIG_KEYBOARD_GPIO=y
CONFIG_KEYBOARD_GPIO_POLLED=y


# CONFIG_DW_WATCHDOG is not set
#
# Automatically generated file based on tn3399 v3 hardware specification
# Linux/arm64 6.12.0 Kernel Configuration
#
# ----------------------------------------------------------------------
# 核心与架构 (Core and Architecture - RK3399)
# ----------------------------------------------------------------------
CONFIG_ARM64=y
CONFIG_64BIT=y
CONFIG_MMU=y
CONFIG_PGTABLE_LEVELS=4
CONFIG_ARM64_4K_PAGES=y
CONFIG_ARM64_VA_BITS_48=y
CONFIG_NR_CPUS=8
CONFIG_HOTPLUG_CPU=y
CONFIG_SCHED_HRTICK=y
CONFIG_TICK_ONESHOT=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_PREEMPT=y
CONFIG_HZ_300=y
CONFIG_COMPAT=y
CONFIG_SWP_EMULATION=y
CONFIG_KALLSYMS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_AIO=y
CONFIG_CPU_BIG_LITTLE=y
CONFIG_SCHED_HMP=y

#
# Platform selection - Rockchip RK3399
#
CONFIG_ARCH_ROCKCHIP=y

#
# Boot options
#
CONFIG_ARM_PSCI_FW=y
CONFIG_OF=y
CONFIG_OF_FLATTREE=y
CONFIG_OF_UNITTEST=y
CONFIG_ZBOOT_ROM_TEXT=y
CONFIG_ZBOOT_ROM_BSS=y

#
# 处理器功率管理 (CPU Power Management)
#
CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_CPU_PM=y
CONFIG_CPU_IDLE=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_STAT=y
CONFIG_CPUFREQ_DT=y
CONFIG_CPUFREQ_DT_PLATDEV=y
CONFIG_CPUFREQ_GOV_SCHEDUTIL=y
CONFIG_PM_GENERIC_DOMAINS=y
CONFIG_PM_GENERIC_DOMAINS_OF=y

# DDR3 控制器 (DMC)
CONFIG_PM_DEVFREQ=y
CONFIG_DEVFREQ_GOV_SIMPLE_ONDEMAND=y
CONFIG_ARM_RK3399_DMC_DEVFREQ=y

#
# 时钟、复位、PHY (Clock, Reset, PHY)
#
CONFIG_COMMON_CLK=y
CONFIG_CLK_ROCKCHIP=y
CONFIG_CLK_RK3399=y
CONFIG_RESET_CONTROLLER=y
CONFIG_GENERIC_PHY=y
CONFIG_PHY_ROCKCHIP_PCIE=y
CONFIG_PHY_ROCKCHIP_INNO_USB2_PHY=y
CONFIG_PHY_ROCKCHIP_TYPEC_PHY=y

#
# ----------------------------------------------------------------------
# 设备驱动 (Device Drivers)
# ----------------------------------------------------------------------

#
# 多功能设备 (MFD) - RK808D PMU
#
CONFIG_MFD_CORE=y
CONFIG_MFD_RK808=y
CONFIG_REGULATOR=y
CONFIG_REGULATOR_RK808=y

#
# PINCTRL & GPIO
#
CONFIG_PINCTRL=y
CONFIG_PINCTRL_ROCKCHIP=y
CONFIG_GPIOLIB=y
CONFIG_GPIO_ROCKCHIP=y

#
# DMA Engine
#
CONFIG_DMA_ENGINE=y
CONFIG_ROCKCHIP_DMA=y

#
# I2C (用于 RK808D, ALC5640, 358775G)
#
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_DESIGNWARE_CORE=y
CONFIG_I2C_DESIGNWARE_PLATFORM=y
CONFIG_I2C_ROCKCHIP=y

#
# 串行端口 (UART - SP3232EEN)
#
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_DW=y

#
# MMC/eMMC (SanDisk SDINBDG4-16G)
#
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_DW=y
CONFIG_MMC_DW_ROCKCHIP=y
CONFIG_MMC_SDIO_UNIFIED_CLS=y

#
# eMMC/闪存的 I/O 优化
#
CONFIG_BLK_DEV_INITRD=y
CONFIG_BLK_MQ_PCI=y
CONFIG_SENSORS_CORE=6

#
# USB Support (FE1.1s Hub, VL817-Q7 Hub)
#
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_ARCH_HAS_HCD=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PLATFORM=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_OF_PLATFORM=y
CONFIG_USB_HUB=y
CONFIG_USB_COMMON=y

#
# USB Storage (JMS578 SATA Bridge)
#
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y

#
# PCI bus support (用于可能的板载设备或M.2扩展)
#
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y
CONFIG_PCIE_DW=y
CONFIG_PCIE_ROCKCHIP=y
CONFIG_PCIE_ROCKCHIP_HOST=y

#
# Networking (RTL8211E PHY + Rockchip MAC)
#
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_NET_CORE=y
CONFIG_ETHERNET=y
CONFIG_MII=y
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y
CONFIG_STMMAC_RK=y
CONFIG_NET_VENDOR_REALTEK=y
CONFIG_PHYLIB=y
CONFIG_FIXED_PHY=y
CONFIG_REALTEK_PHY=y

#
# Wireless (AP6255 - Broadcom Wi-Fi/BT)
#
CONFIG_WLAN=y
CONFIG_CFG80211=y
CONFIG_CFG80211_DEFAULT_PS=y
CONFIG_BRCM_FDC=y
CONFIG_BRCMFMAC=y
CONFIG_BRCMUTIL=y

CONFIG_BT=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_BCM=y
CONFIG_BT_HCIUART_NOKIA=y

#
# Graphics support (RK3399 + HDMI/LVDS)
#
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_ROCKCHIP=y
CONFIG_DRM_RK3399=y
CONFIG_DRM_PANEL_SIMPLE=y
CONFIG_DRM_MIPI_DSI=y
# 358775G bridge support may require a specific DSI or bridge driver, using generic ones
CONFIG_DRM_DW_HDMI=y

#
# VPU/Video support (RK3399 VDEC)
#
CONFIG_VIDEO_DEV=y
CONFIG_VIDEO_V4L2=y
CONFIG_VIDEO_ROCKCHIP_VDEC=m

#
# Sound (ALC5640 Codec)
#
CONFIG_SND=y
CONFIG_SND_SOC=y
CONFIG_SND_SOC_ROCKCHIP=y
CONFIG_SND_SOC_ROCKCHIP_I2S=y
CONFIG_SND_SOC_ROCKCHIP_PDM=y
CONFIG_SND_SOC_ROCKCHIP_SPDIF=y
CONFIG_SND_SOC_RK3399_I2S=y
CONFIG_SND_SOC_RT5640=y
CONFIG_SND_SOC_SIMPLE_CARD=y

# PANS4258 Amp likely needs GPIO/regulator control, assume simple GPIO
# or no dedicated kernel driver, rely on I2S codec output.